{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.intellidue.dev/v1/current_project_state.schema.json",
  "title": "CurrentProjectState",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "system", "project_id", "project_name", "status", "accepted_product_class", "project_boundaries", "next"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "system": {"type": "string", "minLength": 1},
    "project_id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9_-]{2,63}$"},
    "project_name": {"type": "string", "minLength": 1, "maxLength": 200},
    "status": {"enum": ["CURRENT", "ARCHIVED", "SUPERSEDED"]},
    "accepted_product_class": {"enum": ["PRELIMINARY_RED_FLAG_DD", "FINAL_FULL_DD"]},
    "project_boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": ["critical_gates_open", "restricted_outputs", "decision_ready"],
      "properties": {
        "critical_gates_open": {"type": "integer", "minimum": 0},
        "restricted_outputs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}, "maxItems": 100},
        "decision_ready": {"type": "boolean"}
      }
    },
    "next": {"type": "string", "minLength": 1, "maxLength": 300}
  }
}
