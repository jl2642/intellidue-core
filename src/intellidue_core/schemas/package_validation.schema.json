{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.intellidue.dev/v1/package_validation.schema.json",
  "title": "PackageValidation",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "project_id", "status", "tests", "non_regression"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "project_id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9_-]{2,63}$"},
    "status": {"enum": ["PASS", "FAIL"]},
    "tests": {
      "type": "object",
      "additionalProperties": false,
      "required": ["passed", "failed"],
      "properties": {
        "passed": {"type": "integer", "minimum": 0},
        "failed": {"type": "integer", "minimum": 0}
      }
    },
    "non_regression": {
      "type": "object",
      "additionalProperties": false,
      "required": ["critical_gates_open", "restricted_outputs", "decision_ready"],
      "properties": {
        "critical_gates_open": {"type": "integer", "minimum": 0},
        "restricted_outputs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}, "maxItems": 100},
        "decision_ready": {"type": "boolean"}
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "PASS"}}},
      "then": {"properties": {"tests": {"properties": {"failed": {"const": 0}}}}}
    }
  ]
}
