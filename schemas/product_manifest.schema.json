{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProductManifest",
  "type": "object",
  "required": [
    "root",
    "files"
  ],
  "additionalProperties": false,
  "properties": {
    "root": {
      "type": "string",
      "minLength": 1
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "size_bytes",
          "sha256"
        ],
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 0
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      }
    }
  }
}
